# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=resona-media

# Redis (Upstash for prod, localhost:6379 for local dev)
REDIS_URL=rediss://:[password]@[host].upstash.io:6379

# JWT
JWT_SECRET=replace_with_32+_char_random_string
JWT_REFRESH_SECRET=replace_with_different_32+_char_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=168h

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Google Translate API
GOOGLE_TRANSLATE_API_KEY=your_api_key

# App
PORT=8080
FRONTEND_URL=http://localhost:5173
APP_ENV=development

# VRS
VRS_TRENDING_THRESHOLD=0.75
VRS_SHARE_VELOCITY_HOURS=2
